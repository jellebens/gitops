        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (site_id) (jupiter_savings_discharged_today_kwh{site_id=~\"$site_id\"})", "legendFormat": "discharged", "instant": true }
