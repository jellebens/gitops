  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 15,
      "type": "timeseries",
      "title": "Load: actual vs forecast (now-24h .. now+24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 18,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 2,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 0,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": true,
            "axisPlacement": "auto",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*actual.*"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Actual"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 30
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*forecast.*"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Forecast"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    6
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "zeus_load_kwh",
          "format": "table",
          "instant": true,
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "namespace": true,
              "pod": true,
              "endpoint": true,
              "container": true,
              "service": true,
              "prometheus": true,
              "prometheus_replica": true
            },
            "indexByName": {},
            "renameByName": {}
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "ts",
                "destinationType": "number"
              }
            ],
            "fields": {}
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "ts",
                "destinationType": "time"
              }
            ],
            "fields": {}
          }
        },
        {
          "id": "partitionByValues",
          "options": {
            "fields": [
              "kind"
            ],
            "keepFields": false,
            "naming": {
              "asLabels": false
            }
          }
        }
      ]
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Forecast accuracy (7d)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.15
              },
              {
                "color": "red",
                "value": 0.3
              }
            ]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "MAPE"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 20
                    },
                    {
                      "color": "red",
                      "value": 40
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg_over_time(abs(max(zeus_realized_load_kwh) - max(zeus_forecast_load_kwh offset 1h))[7d:1h])",
          "legendFormat": "MAE",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * avg_over_time((abs(max(zeus_realized_load_kwh) - max(zeus_forecast_load_kwh offset 1h)) / clamp_min(max(zeus_realized_load_kwh), 0.05))[7d:1h])",
          "legendFormat": "MAPE",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": [
    "zeus",
    "forecast"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-24h",
    "to": "now+24h"
  },
  "timepicker": {
    "hidden": true
  },
  "timezone": "browser",
  "title": "Zeus — Load Forecast",
  "uid": "zeus-forecast",
  "version": 1,
  "weekStart": ""
}
