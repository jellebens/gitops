    {
      "id": 2,
      "type": "timeseries",
      "title": "Cumulative savings (€) — rolling 30d",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5,
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" }
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "savings_eur" },
            "properties": [ { "id": "custom.hideFrom", "value": { "viz": true, "legend": true, "tooltip": true } } ]
          }
        ]
      },
      "options": {
        "legend": { "showLegend": false, "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "zeus_daily_savings_eur",
          "format": "table",
          "instant": true,
          "range": false,
          "legendFormat": "__auto"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "namespace": true,
              "pod": true,
              "service": true,
              "prometheus": true,
              "prometheus_replica": true
            },
            "indexByName": {},
            "renameByName": { "Value": "savings_eur" }
          }
        },
        { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "date", "desc": true } ] } },
        { "id": "limit", "options": { "limitField": 31 } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "date", "desc": false } ] } },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [ { "targetField": "date", "destinationType": "time", "dateFormat": "YYYY-MM-DD" } ],
            "fields": {}
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "cumulativeFunctions",
            "cumulative": { "field": "savings_eur", "reducer": "sum" },
            "alias": "Cumulative €",
            "replaceFields": false
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Time in mode per day (hours) — charging / passthrough / discharging",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "decimals": 1,
          "min": 0,
          "max": 24,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "barAlignment": 0,
            "axisPlacement": "auto",
            "axisSoftMax": 24,
            "stacking": { "mode": "normal", "group": "A" },
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never"
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "charging" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "passthrough" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "discharging" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ]
          }
        ]
      },
      "options": {
        "legend": { "showLegend": true, "calcs": [ "sum" ], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg_over_time((max by (mode) (zeus_working_mode))[1d:10m]) * 24",
          "legendFormat": "{{mode}}",
          "interval": "1d",
          "range": true,
          "instant": false
        }
      ]
    }
