    {
      "id": 19,
      "type": "stat",
      "title": "Tomorrow's day-ahead (BE): expected vs present",
      "description": "Card #172. Combined state of jupiter_price_tomorrow_expected (0/1 process-global clock gauge, flips at the 15:00 Europe/Brussels publish-by, DST-aware) and jupiter_price_tomorrow_present{zone} (tomorrow's market-local-date slots present in the served curve): state = expected + 2×present. 'Not expected yet' before 15:00 is the normal morning; MISSING past 15:00 is the JupiterPriceTomorrowMissing alert condition (warning at 15:45, critical at 17:00). Shows 'awaiting metrics' until the jupiter release that ships these series (PR #52) is deployed.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 10, "x": 0, "y": 55 },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "noValue": "awaiting metrics (pre-#52 image)",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] },
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "Not expected yet (before 15:00)", "color": "blue" },
              "1": { "text": "MISSING — past 15:00 publish-by", "color": "red" },
              "2": { "text": "Present (early, before 15:00)", "color": "green" },
              "3": { "text": "Present", "color": "green" }
            } }
          ]
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(jupiter_price_tomorrow_expected) + 2 * max(jupiter_price_tomorrow_present)", "instant": true } ]
    },
