      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(jupiter_price_tomorrow_expected) + 2 * max(jupiter_price_tomorrow_present)", "legendFormat": "tomorrow curve state" } ]
