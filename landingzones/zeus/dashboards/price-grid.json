{
  "annotations": { "list": [
    {
      "name": "Day-ahead publish-by — 15:00 Europe/Brussels (#172)",
      "enable": true,
      "hide": false,
      "iconColor": "orange",
      "datasource": { "type": "datasource", "uid": "-- Grafana --" },
      "target": {
        "queryType": "timeRegions",
        "matchAny": false,
        "tags": [],
        "type": "dashboard",
        "timeRegion": { "from": "15:00", "to": "15:15", "timezone": "Europe/Brussels" }
      },
      "filter": { "exclude": false, "ids": [ 6 ] }
    }
  ] },
  "description": "Price feed + grid monitor (card #130). Day-ahead curve with coverage, per-cycle price-source timeline (#108 soak evidence), historical cheap/expensive strip, grid import/export, and quarter-hour capacity-peak tracking (#98/#100).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Consumption analysis (daily peaks, cost)",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/zeus-consumption",
      "targetBlank": false
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Price feed status (this cycle)",
      "description": "zeus_price_source: which tier served this cycle's price curve. Partial = the curve covers the horizon start but not its end, so the optimizer sees a LOCF-flat tail.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "Healthy (jupiter / entsoe)", "color": "green" },
              "1": { "text": "Fallback — direct entsoe", "color": "orange" },
              "2": { "text": "Last-good cache", "color": "yellow" },
              "3": { "text": "None — SAFE HOLD", "color": "red" },
              "4": { "text": "Partial — LOCF flat tail", "color": "light-red" }
            } }
          ]
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(zeus_price_source)", "instant": true } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Day-ahead curve length",
      "description": "jupiter_price_curve_points ÷ 4 (15-min native): hours of raw price data in the served BE curve. ~24 h = today only (tomorrow not yet published, normal before ~13:00 CET); ≥28 h = tomorrow arrived. The optimizer horizon is 36 h — anything shorter is LOCF-flat-lined past the coverage end (the 'covers only Xh of the 36h horizon' warning).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "h", "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 20 },
            { "color": "green", "value": 28 } ] },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "value", "graphMode": "area", "justifyMode": "center" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(jupiter_price_curve_points) / 4" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Degraded cycles (range)",
      "description": "Cycles served by a degraded price source (fallback / cache / none / partial) over the dashboard time range.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 5, "x": 10, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 24 } ] },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "value", "graphMode": "area", "justifyMode": "center" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(zeus_price_degraded_total[$__range]))" } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Import price now",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 15, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR", "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "value", "graphMode": "area", "justifyMode": "center" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(jupiter_reporting_import_price_eur_per_kwh)" } ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Now: cheap → expensive",
      "description": "Where the current slot's price sits in today's range (0 = cheapest, 100 = most expensive).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 5, "x": 19, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 20 },
            { "color": "red", "value": 80 } ] },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "orientation": "auto", "textMode": "value", "colorMode": "value", "graphMode": "area", "justifyMode": "center" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(jupiter_reporting_price_position_pct)" } ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "All-in import price — realized (€/kWh, InfluxDB long history)",
      "description": "Per-cycle all-in import price from zeus_state (durable InfluxDB copy, survives Prometheus retention). Colored by position in the visible range: green = cheap, red = expensive. Zeus exposes no per-slot price series for TOMORROW (zeus_price_today_eur_per_kwh is today-only and zeus_forecast carries no price field) — forward coverage is monitored via the curve-length stat and the price-source timeline below.",
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "gridPos": { "h": 9, "w": 14, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR", "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "percentage", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 20 },
            { "color": "red", "value": 80 } ] },
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "fillOpacity": 12, "gradientMode": "scheme", "showPoints": "never", "spanNulls": true, "axisPlacement": "auto" },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [ { "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb" },
        "query": "from(bucket: \"zeus\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"zeus_state\" and r._field == \"import_price_eur\")\n  |> aggregateWindow(every: 15m, fn: mean, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\"])\n  |> rename(columns: {_value: \"Import price (€/kWh)\"})\n  |> sort(columns: [\"_time\"])" } ]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Import-price horizon — today + TOMORROW by 15-min slot (green=cheap · red=priciest · flat tail = LOCF)",
      "description": "Full optimizer-horizon import price (zeus_price_horizon_eur_per_kwh, 144 slots ≈ 36 h) plotted from the current slot forward — includes TODAY and TOMORROW, unlike the today-only curve zeus previously exported. slot_ts (epoch ms) is converted to a real time field for the X axis (labelsToFields → convertFieldType → organize → sortBy). Bars are colored by price percentile (green=cheapest 20%, orange=mid, red=priciest 20%). REAL price data covers only the first zeus_price_horizon_covered_hours hours this cycle (see the 'Day-ahead curve length' stat above); every slot beyond now + that many hours is a LOCF-flat synthetic tail (the last real value carried forward) — it appears as a dead-flat plateau at the right-hand end of the curve, which is the non-real region. Per-slot programmatic shading of that tail is not possible from these two metrics alone (the slot_ts label can't be compared to now+covered_hours in PromQL, and Grafana filter/calc transforms have no dynamic boundary), so the tail is identified by the flat plateau + this note rather than a colored overlay.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 10, "x": 14, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR", "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "percentage", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 20 },
            { "color": "red", "value": 80 } ] },
          "custom": { "lineWidth": 1, "fillOpacity": 90, "gradientMode": "none", "axisPlacement": "auto", "axisLabel": "" },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "orientation": "vertical", "xField": "time", "showValue": "never", "stacking": "none", "barWidth": 0.9, "groupWidth": 1, "fullHighlight": true, "xTickLabelSpacing": 100, "xTickLabelRotation": -45, "legend": { "showLegend": false, "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (slot_ts) (zeus_price_horizon_eur_per_kwh)", "format": "table", "instant": true, "legendFormat": "€/kWh" }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns", "keepLabels": [ "slot_ts" ] } },
        { "id": "convertFieldType", "options": { "conversions": [ { "targetField": "slot_ts", "destinationType": "time", "dateFormat": "x" } ], "fields": {} } },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": {}, "renameByName": { "slot_ts": "time", "Value": "€/kWh" } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "time" } ] } }
      ]
    },
    {
      "id": 8,
      "type": "state-timeline",
      "title": "Price source per cycle — #108 soak evidence",
      "description": "zeus_price_source codes: 0 = healthy (jupiter-primary / entsoe primary / immutable cache-fresh), 1 = fallback (jupiter unreachable → direct entsoe, or HA fallback entity), 2 = last-good cache, 3 = none (safe hold), 4 = partial coverage (LOCF flat tail). Codes 0/1/2/4 fold jupiter and direct-entsoe serves together — the per-hour jupiter serve-label panel below tells them apart.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "healthy (jupiter/entsoe)", "color": "green" },
              "1": { "text": "fallback — direct entsoe", "color": "orange" },
              "2": { "text": "cache", "color": "yellow" },
              "3": { "text": "SAFE HOLD", "color": "red" },
              "4": { "text": "partial — flat tail", "color": "light-red" }
            } }
          ]
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "mergeValues": true, "rowHeight": 0.9, "showValue": "auto", "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(zeus_price_source)", "legendFormat": "price source" } ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Degraded price cycles per hour",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "decimals": 0, "min": 0,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80, "gradientMode": "none", "showPoints": "never", "spanNulls": false, "axisPlacement": "auto" },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(zeus_price_degraded_total[1h]))", "legendFormat": "degraded cycles / h" } ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Jupiter price-service serves by source label (per hour)",
      "description": "jupiter_price_curve_serves_total — the price-service's own zeus-parity source labels. Distinguishes what JUPITER served (primary / cache-fresh / cache / *-partial / none) from how zeus classified its own serve in the timeline above.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "decimals": 0, "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80, "gradientMode": "none", "showPoints": "never", "spanNulls": false, "axisPlacement": "auto", "stacking": { "mode": "normal", "group": "A" } },
          "mappings": []
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "primary" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "cache-fresh" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "super-light-green" } } ] },
          { "matcher": { "id": "byName", "options": "primary-partial" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "light-red" } } ] },
          { "matcher": { "id": "byName", "options": "cache" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } } ] },
          { "matcher": { "id": "byName", "options": "cache-partial" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "none" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": [] }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (source_label) (increase(jupiter_price_curve_serves_total[1h]))", "legendFormat": "{{source_label}}" } ]
    },
