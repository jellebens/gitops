    {
      "id": 4,
      "type": "state-timeline",
      "title": "ENTSO-E cooldown / background refresh (service side)",
      "description": "jupiter_price_cooldown_active: 1 while the process-global ENTSO-E retry cooldown is up (retries exhausted recently; fetches go single-attempt) — deliberately NOT per-zone, an ENTSO-E outage is upstream of every zone. jupiter_price_refresh_inflight: 1 while a per-zone single-flight background refresh is running (benign; serves never wait on it).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 70,
            "spanNulls": false
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "idle",
                  "color": "green",
                  "index": 0
                },
                "1": {
                  "text": "COOLDOWN",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
