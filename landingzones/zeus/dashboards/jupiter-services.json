    {
      "id": 3,
      "type": "state-timeline",
      "title": "zeus PRICE_SOURCE code (consumer side)",
      "description": "zeus_price_source, the code zeus reported for each optimization cycle's price serve. With prices.source=jupiter: 0 = jupiter primary/cache-fresh (healthy), 1 = direct ENTSO-E fallback (price-service unreachable), 2 = a cache-tier serve (jupiter-cache or zeus's own last-good cache; also any unknown label, fail-loud), 3 = nothing servable — safe hold, 4 = partial horizon coverage (tail LOCF; routine near end of horizon, self-heals at ~13:00 CET day-ahead publication).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 10
