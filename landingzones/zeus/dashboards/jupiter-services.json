    {
      "id": 1,
      "type": "timeseries",
      "title": "Curve serves by source_label (per hour)",
      "description": "sum by (source_label) of increase(jupiter_price_curve_serves_total[1h]). Zeus-parity taxonomy: primary and cache-fresh are HEALTHY (cache-fresh = cache-first serve of immutable, already-published day-ahead prices); *-partial = curve covers the horizon start but not its end (consumer LOCF-flat-lines the tail); none = the machine-readable 503. NOTE: prometheus_client counters only expose a label after its first observation since pod start, so an absent label here means 'not observed yet', not zero forever.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 75,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "serves / h",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
