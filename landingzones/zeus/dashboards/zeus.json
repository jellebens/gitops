      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "sortBy": [
          {
            "displayName": "Weekday",
            "desc": false
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "import \"date\"\nimport \"timezone\"\noption location = timezone.location(name: \"Europe/Brussels\")\nfrom(bucket: \"zeus\")\n  |> range(start: -28d)\n  |> filter(fn: (r) => r._measurement == \"zeus_state\" and r._field == \"grid_power_w\")\n  |> aggregateWindow(every: 1h, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with\n       wd:   (if date.weekDay(t: r._time) == 1 then \"1 Mon\" else if date.weekDay(t: r._time) == 2 then \"2 Tue\" else if date.weekDay(t: r._time) == 3 then \"3 Wed\" else if date.weekDay(t: r._time) == 4 then \"4 Thu\" else if date.weekDay(t: r._time) == 5 then \"5 Fri\" else if date.weekDay(t: r._time) == 6 then \"6 Sat\" else \"7 Sun\"),\n       hour: (if date.hour(t: r._time) < 10 then \"0\" else \"\") + string(v: date.hour(t: r._time)) }))\n  |> group(columns: [\"wd\", \"hour\"])\n  |> mean()\n  |> map(fn: (r) => ({ weekday: r.wd, hour: r.hour, kW: r._value / 1000.0 }))\n  |> group()\n  |> sort(columns: [\"hour\"])\n  |> keep(columns: [\"weekday\", \"hour\", \"kW\"])"
        }
      ],
      "transformations": [
        {
          "id": "groupingToMatrix",
          "options": {
            "columnField": "hour",
            "rowField": "weekday",
            "valueField": "kW"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "weekday\\hour": "weekday"
            }
          }
        }
      ]
