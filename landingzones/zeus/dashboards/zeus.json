      "pluginVersion": "10.0.0",
      "title": "Today €/kWh by hour — green = cheapest 20%, orange = mid, red = priciest 20%, blue = now",
      "type": "barchart",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "label_replace(max by (hour) (zeus_price_today_eur_per_kwh unless on (hour) zeus_price_now_marker_eur_per_kwh), \"hour\", \"$1:00\", \"hour\", \"(.*)\")",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "label_replace(max by (hour) (zeus_price_now_marker_eur_per_kwh), \"hour\", \"$1:00\", \"hour\", \"(.*)\")",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "hour",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true
            },
            "indexByName": {},
            "renameByName": {
              "Value #A": "€/kWh",
              "Value #B": "now"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "hour"
              }
            ]
          }
        }
      ]
    },
