    {
      "id": 50,
      "type": "stat",
      "title": "System health  —  green = OK · amber = warn · red = critical",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "OK",
                  "index": 0
                },
                "1": {
                  "text": "WARN",
                  "index": 1
                },
                "2": {
                  "text": "CRIT",
                  "index": 2
                }
              }
            }
          ],
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "noValue": "?"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "wideLayout": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "((max(up{namespace=\"zeus\", job=\"zeus-metrics\"}) < bool 1) * 2) or vector(2)",
          "legendFormat": "zeus",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "((max(jupiter_lar_control_available) < bool 1) * 2) or vector(2)",
          "legendFormat": "Home Assistant",
          "instant": true
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "((max(kube_pod_status_ready{namespace=\"influxdb\", pod=~\"influxdb-influxdb2-.*\", condition=\"true\"}) < bool 1) * 2) or vector(2)",
          "legendFormat": "InfluxDB",
          "instant": true
        },
        {
          "refId": "D",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "((time() - max(jupiter_lar_last_cycle_timestamp_seconds) > bool 900) + (time() - max(jupiter_lar_last_cycle_timestamp_seconds) > bool 1800)) or vector(2)",
          "legendFormat": "Last cycle",
          "instant": true
        },
        {
          "refId": "E",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "((sum(increase(zeus_cycle_failures_total[15m])) > bool 0) * 2) or vector(2)",
          "legendFormat": "Failed cycles",
          "instant": true
        },
        {
          "refId": "F",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "((max(zeus_solver_optimal) < bool 1) * 1) or vector(2)",
          "legendFormat": "Solver",
          "instant": true
        },
        {
          "refId": "G",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(((100 * sum(rate(container_cpu_usage_seconds_total{namespace=\"zeus\", container!=\"\"}[5m])) / sum(kube_pod_container_resource_limits{namespace=\"zeus\", resource=\"cpu\"})) > bool 70) + ((100 * sum(rate(container_cpu_usage_seconds_total{namespace=\"zeus\", container!=\"\"}[5m])) / sum(kube_pod_container_resource_limits{namespace=\"zeus\", resource=\"cpu\"})) > bool 90)) or vector(2)",
          "legendFormat": "zeus CPU",
          "instant": true
        },
        {
          "refId": "H",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(((100 * sum(container_memory_working_set_bytes{namespace=\"zeus\", container!=\"\"}) / sum(kube_pod_container_resource_limits{namespace=\"zeus\", resource=\"memory\"})) > bool 75) + ((100 * sum(container_memory_working_set_bytes{namespace=\"zeus\", container!=\"\"}) / sum(kube_pod_container_resource_limits{namespace=\"zeus\", resource=\"memory\"})) > bool 90)) or vector(2)",
          "legendFormat": "zeus Mem",
          "instant": true
        },
        {
          "refId": "I",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "((sum(kube_pod_container_status_restarts_total{namespace=\"zeus\"}) > bool 0) * 1) or vector(2)",
          "legendFormat": "zeus restarts",
          "instant": true
        },
        {
          "refId": "J",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(((100 * sum(rate(container_cpu_usage_seconds_total{namespace=\"influxdb\", pod=~\"influxdb-influxdb2-.*\", container!=\"\"}[5m])) / sum(kube_pod_container_resource_limits{namespace=\"influxdb\", pod=~\"influxdb-influxdb2-.*\", resource=\"cpu\"})) > bool 70) + ((100 * sum(rate(container_cpu_usage_seconds_total{namespace=\"influxdb\", pod=~\"influxdb-influxdb2-.*\", container!=\"\"}[5m])) / sum(kube_pod_container_resource_limits{namespace=\"influxdb\", pod=~\"influxdb-influxdb2-.*\", resource=\"cpu\"})) > bool 90)) or vector(2)",
          "legendFormat": "InfluxDB CPU",
          "instant": true
        },
        {
          "refId": "K",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(((100 * sum(container_memory_working_set_bytes{namespace=\"influxdb\", pod=~\"influxdb-influxdb2-.*\", container!=\"\"}) / sum(kube_pod_container_resource_limits{namespace=\"influxdb\", pod=~\"influxdb-influxdb2-.*\", resource=\"memory\"})) > bool 75) + ((100 * sum(container_memory_working_set_bytes{namespace=\"influxdb\", pod=~\"influxdb-influxdb2-.*\", container!=\"\"}) / sum(kube_pod_container_resource_limits{namespace=\"influxdb\", pod=~\"influxdb-influxdb2-.*\", resource=\"memory\"})) > bool 90)) or vector(2)",
          "legendFormat": "InfluxDB Mem",
          "instant": true
        },
        {
          "refId": "L",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(((100 * sum(kubelet_volume_stats_used_bytes{namespace=\"influxdb\", persistentvolumeclaim!~\".*backup.*\"}) / sum(kubelet_volume_stats_capacity_bytes{namespace=\"influxdb\", persistentvolumeclaim!~\".*backup.*\"})) > bool 75) + ((100 * sum(kubelet_volume_stats_used_bytes{namespace=\"influxdb\", persistentvolumeclaim!~\".*backup.*\"}) / sum(kubelet_volume_stats_capacity_bytes{namespace=\"influxdb\", persistentvolumeclaim!~\".*backup.*\"})) > bool 90)) or vector(2)",
          "legendFormat": "InfluxDB Disk",
          "instant": true
        },
        {
          "refId": "M",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "((sum(kube_pod_container_status_restarts_total{namespace=\"influxdb\", pod=~\"influxdb-influxdb2-.*\"}) > bool 0) * 1) or vector(2)",
          "legendFormat": "InfluxDB restarts",
          "instant": true
        }
      ]
